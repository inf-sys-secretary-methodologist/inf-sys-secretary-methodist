FROM golang:1.25-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /agentsim ./cmd/agentsim

FROM alpine:3.23
RUN apk --no-cache add ca-certificates
COPY --from=builder /agentsim /agentsim
ENTRYPOINT ["/agentsim"]
CMD ["--api-url", "http://backend:8080", "--seed-users", "--scenario", "all", "--no-llm"]
