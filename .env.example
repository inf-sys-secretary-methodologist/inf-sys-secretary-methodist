# Environment
ENVIRONMENT=development
VERSION=0.2.0

# Server Configuration
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=120s

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inf_sys_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Logging
LOG_LEVEL=info

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# JWT Authentication (для Docker Compose)
POSTGRES_PASSWORD=postgres
JWT_ACCESS_SECRET=dev-jwt-secret-key-change-in-production
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-key-change-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Composio Configuration (для email и Telegram уведомлений)
COMPOSIO_API_KEY=your-composio-api-key-here
COMPOSIO_ENTITY_ID=your-composio-entity-id-here
COMPOSIO_MCP_CONFIG_ID=your-composio-mcp-config-id-here

# Telegram Bot Configuration (для привязки аккаунтов)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret-here
# Chat ID для Grafana алертов (можно получить через @userinfobot или API)
TELEGRAM_CHAT_ID=-100123456789

# Docker Compose Configuration (опционально - для переопределения портов)
BACKEND_PORT=8080
FRONTEND_PORT=3000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# MinIO/S3 Storage Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_BUCKET_NAME=documents
S3_REGION=us-east-1
S3_USE_SSL=false
S3_MAX_FILE_SIZE=104857600

# Database Advanced Configuration (опционально)
DB_SSL_MODE=disable

# Redis Advanced Configuration (опционально)
REDIS_POOL_SIZE=10

# Logging Format (опционально - для Docker)
LOG_FORMAT=json

# Sentry Error Tracking
SENTRY_DSN=

# 1C Integration Configuration
INTEGRATION_1C_ENABLED=false
INTEGRATION_1C_BASE_URL=http://1c-server/base/odata/standard.odata
INTEGRATION_1C_USERNAME=1c_user
INTEGRATION_1C_PASSWORD=1c_password
INTEGRATION_1C_TIMEOUT=30s
INTEGRATION_1C_MAX_RETRIES=3
INTEGRATION_1C_RETRY_DELAY=5s
INTEGRATION_1C_EMPLOYEE_CATALOG=Catalog_Сотрудники
INTEGRATION_1C_STUDENT_CATALOG=Catalog_Студенты
INTEGRATION_1C_SYNC_CRON_EMPLOYEE=0 0 */6 * * *
INTEGRATION_1C_SYNC_CRON_STUDENT=0 0 */6 * * *
INTEGRATION_1C_BATCH_SIZE=100

# Web Push Notifications (VAPID keys)
# Generate keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Monitoring Stack Configuration (compose.monitoring.yml)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3001
LOKI_PORT=3100

# Distributed Tracing (OpenTelemetry)
TRACING_ENABLED=false
TRACING_OTLP_ENDPOINT=otel-collector:4317
TRACING_SAMPLING_RATE=0.1
TRACING_SERVICE_NAME=inf-sys-secretary-methodist

# Tempo & OTEL Collector ports (compose.monitoring.yml)
TEMPO_HTTP_PORT=3200
TEMPO_GRPC_PORT=9095
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_HEALTH_PORT=13133

# Timezone (для Uptime Kuma и других сервисов)
TZ=Europe/Moscow

# n8n Workflow Automation (docker compose --profile automation)
# Docs: https://docs.n8n.io/
N8N_PORT=5678
N8N_PASSWORD=change-me-in-production
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_WEBHOOK_URL=http://localhost:5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_DB_TYPE=postgresdb
N8N_DB_NAME=n8n

# AI/RAG Configuration
AI_ENABLED=false
AI_PROVIDER=openai                                 # Chat provider: "anthropic" or "openai"
ANTHROPIC_API_KEY=                                 # Anthropic API key (for chat, if provider=anthropic)
ANTHROPIC_BASE_URL=https://api.anthropic.com       # Anthropic API base URL
OPENAI_API_KEY=sk-your-openai-api-key              # OpenAI API key (for embeddings)
OPENAI_BASE_URL=https://api.openai.com/v1          # OpenAI API base URL (for embeddings)
AI_CHAT_API_KEY=                                   # Chat API key for OpenAI-compatible providers (Gemini, Groq)
AI_CHAT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai  # Chat base URL
AI_EMBEDDING_PROVIDER=gemini                       # Embedding provider: "gemini" or "openai"
AI_EMBEDDING_API_KEY=                              # Embedding provider API key (Gemini key)
AI_EMBEDDING_MODEL=gemini-embedding-001            # Model for embeddings
AI_EMBEDDING_DIMENSIONALITY=1536                   # Embedding vector size (1536 recommended, pgvector max 2000 for IVFFlat)
AI_CHAT_MODEL=gemini-2.5-flash                     # Model for chat
AI_MAX_TOKENS=2048                                 # Max tokens for chat response
AI_TEMPERATURE=0.3                                 # Temperature for chat (0.0-2.0, low = less hallucination for RAG)
AI_CHUNK_SIZE=512                                  # Chunk size in tokens for document splitting
AI_CHUNK_OVERLAP=51                                # Overlap between chunks (~10% of chunk_size)
AI_SEARCH_TOP_K=5                                  # Number of similar chunks to retrieve
AI_SEARCH_THRESHOLD=0.7                            # Minimum similarity threshold (0.0-1.0)
AI_TIMEOUT=60s                                     # API request timeout

# AI Fallback Provider (Groq, used when primary provider fails)
AI_FALLBACK_PROVIDER=groq                                                   # Fallback provider name: "groq", "openai", "" (disabled)
AI_FALLBACK_API_KEY=                                                        # Groq API key (gsk_...)
AI_FALLBACK_BASE_URL=https://api.groq.com/openai/v1                        # Groq OpenAI-compatible endpoint
AI_FALLBACK_CHAT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct           # Fallback model

# AI Fallback Embedding Provider (used when primary embedding provider fails)
AI_FALLBACK_EMBEDDING_PROVIDER=openai                                      # Fallback embedding provider: "openai", "gemini", "" (disabled)
AI_FALLBACK_EMBEDDING_API_KEY=                                             # Fallback embedding API key
AI_FALLBACK_EMBEDDING_BASE_URL=https://api.openai.com/v1                   # Fallback embedding base URL
AI_FALLBACK_EMBEDDING_MODEL=text-embedding-3-small                         # Fallback embedding model
AI_FALLBACK_EMBEDDING_DIMENSIONALITY=1536                                  # Fallback embedding vector size
