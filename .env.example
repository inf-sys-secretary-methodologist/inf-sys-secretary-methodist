# Environment
ENVIRONMENT=development
VERSION=0.2.0

# Server Configuration
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=120s

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inf_sys_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Logging
LOG_LEVEL=info

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# JWT Authentication (для Docker Compose)
POSTGRES_PASSWORD=postgres
JWT_ACCESS_SECRET=dev-jwt-secret-key-change-in-production
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-key-change-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Composio Configuration (опционально - для email уведомлений)
COMPOSIO_API_KEY=your-composio-api-key-here
COMPOSIO_ENTITY_ID=your-composio-entity-id-here
COMPOSIO_MCP_CONFIG_ID=your-composio-mcp-config-id-here

# Docker Compose Configuration (опционально - для переопределения портов)
BACKEND_PORT=8080
FRONTEND_PORT=3000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# MinIO/S3 Storage Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_BUCKET_NAME=documents
S3_REGION=us-east-1
S3_USE_SSL=false
S3_MAX_FILE_SIZE=104857600

# Database Advanced Configuration (опционально)
DB_SSL_MODE=disable

# Redis Advanced Configuration (опционально)
REDIS_POOL_SIZE=10

# Logging Format (опционально - для Docker)
LOG_FORMAT=json
