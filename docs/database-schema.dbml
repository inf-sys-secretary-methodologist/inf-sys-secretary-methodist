// Database Schema для Information System Secretary-Methodist
// Визуализация: https://dbdiagram.io/

Project inf_sys_secretary_methodist {
  database_type: 'PostgreSQL'
  Note: '''
    Информационная система секретаря-методиста
    Всего: 74 таблицы (73 + schema_migrations)
    Модули: Auth (2), Users (3), Documents (12), Schedule (13), Tasks (11), Reports (10), Events (4), Announcements (2), Files (2), Notifications (6), Integration (4), Messaging (4)
  '''
}

// ============================================================================
// AUTH MODULE - Аутентификация (2 таблицы)
// ============================================================================

Table users {
  id bigserial [pk, increment]
  email varchar(255) [unique, not null]
  password varchar(255) [not null, note: 'bcrypt hash']
  name varchar(255) [default: '']
  role varchar(50) [not null, note: 'system_admin, methodist, academic_secretary, teacher, student']
  status varchar(50) [not null, default: 'active', note: 'active, inactive, blocked']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    email
    role
    status
  }

  Note: 'Пользователи системы (аутентификация)'
}

Table sessions {
  id bigserial [pk, increment]
  user_id bigint [not null, ref: > users.id]
  refresh_token_hash varchar(255) [unique, not null]
  user_agent varchar(500)
  ip_address varchar(45)
  expires_at timestamp [not null]
  created_at timestamp [not null, default: `now()`]

  indexes {
    user_id
    refresh_token_hash
    expires_at
  }

  Note: 'Сессии пользователей (refresh tokens)'
}

// ============================================================================
// USERS MODULE - Организационная структура (3 таблицы)
// ============================================================================

Table org_departments {
  id bigserial [pk, increment]
  name varchar(100) [not null]
  code varchar(20) [unique, not null]
  description varchar(500)
  parent_id bigint [ref: > org_departments.id, note: 'Иерархия подразделений']
  head_id bigint [ref: > users.id]
  is_active boolean [not null, default: true]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    code
    parent_id
    head_id
    is_active
    name
  }

  Note: 'Организационные подразделения (отличается от академических кафедр)'
}

Table positions {
  id bigserial [pk, increment]
  name varchar(100) [not null]
  code varchar(20) [unique, not null]
  description varchar(500)
  level int [not null, default: 0, note: '0-100, для иерархии']
  is_active boolean [not null, default: true]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    code
    level
    is_active
    name
  }

  Note: 'Должности в организации'
}

Table user_profiles {
  id bigserial [pk, increment]
  user_id bigint [unique, not null, ref: > users.id]
  department_id bigint [ref: > org_departments.id]
  position_id bigint [ref: > positions.id]
  phone varchar(20)
  avatar varchar(500)
  bio varchar(500)
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    user_id
    department_id
    position_id
  }

  Note: 'Расширенные профили пользователей'
}

// ============================================================================
// DOCUMENTS MODULE - Документооборот (12 таблиц)
// ============================================================================

Table document_types {
  id bigserial [pk, increment]
  name varchar(255) [not null, unique]
  code varchar(50) [not null, unique, note: 'memo, order_main, order_hr, directive, etc']
  description text
  template_path varchar(500)
  numbering_pattern varchar(100) [note: 'ПР-{YYYY}-{###}']
  retention_period_months int
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  Note: 'Типы документов (служебки, приказы, распоряжения)'
}

Table document_categories {
  id bigserial [pk, increment]
  name varchar(255) [not null]
  code varchar(50) [not null, unique]
  description text
  parent_category_id bigint [ref: > document_categories.id]
  display_order int [default: 0]
  created_at timestamp [not null, default: `now()`]

  indexes {
    parent_category_id
    code
  }

  Note: 'Иерархические категории документов'
}

Table documents {
  id bigserial [pk, increment]
  document_type_id bigint [not null, ref: > document_types.id]
  category_id bigint [ref: > document_categories.id]

  registration_number varchar(100) [unique]
  title varchar(500) [not null]
  subject text [note: 'О приобретении монитора']
  content text

  author_id bigint [not null, ref: > users.id]
  author_department varchar(255)
  recipient_id bigint [ref: > users.id]
  recipient_external varchar(500)

  status varchar(50) [not null, default: 'draft', note: 'draft, registered, routing, approval, approved, rejected, execution, executed, archived']
  priority varchar(50) [default: 'normal', note: 'low, normal, high, urgent']

  file_name varchar(500)
  file_path varchar(1000)
  file_size bigint
  mime_type varchar(100)

  metadata jsonb [note: 'Гибкие метаданные для разных типов документов']
  search_vector tsvector [note: 'Генерируемое поле для полнотекстового поиска']

  registered_at timestamp
  approved_at timestamp
  approved_by bigint [ref: > users.id]
  executed_at timestamp
  archived_at timestamp

  due_date date
  retention_until date

  deleted_at timestamp
  deleted_by bigint [ref: > users.id]

  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    document_type_id
    category_id
    author_id
    recipient_id
    status
    registration_number
    (registered_at, status)
    created_at
  }

  Note: 'Основная таблица документов'
}

Table document_versions {
  id bigserial [pk, increment]
  document_id bigint [not null, ref: > documents.id]
  version_number int [not null]
  title varchar(500) [note: 'Заголовок на момент версии']
  subject text [note: 'Тема на момент версии']
  content text
  file_path varchar(1000)
  file_size bigint
  mime_type varchar(100)
  storage_key varchar(1000) [note: 'Ключ в MinIO']
  status varchar(50) [note: 'Статус на момент версии']
  metadata jsonb
  changes_description text
  created_by bigint [not null, ref: > users.id]
  created_at timestamp [not null, default: `now()`]

  indexes {
    document_id
    (document_id, version_number) [unique]
    created_at
  }

  Note: 'Версии документов'
}

Table document_version_diffs {
  id bigserial [pk, increment]
  document_id bigint [not null, ref: > documents.id]
  from_version int [not null]
  to_version int [not null]
  changed_fields text[] [not null, default: '{}', note: 'Массив измененных полей']
  diff_data jsonb [note: 'Детали различий {field: {from: ..., to: ...}}']
  created_at timestamp [not null, default: `now()`]

  indexes {
    document_id
    (document_id, from_version, to_version) [unique]
  }

  Note: 'Кэш сравнений между версиями документов'
}

Table document_routes {
  id bigserial [pk, increment]
  document_id bigint [not null, ref: > documents.id]
  approver_id bigint [ref: > users.id]
  approver_role varchar(50) [note: 'admin, secretary, methodist']
  step_order int [not null]
  approval_type varchar(50) [not null, note: 'sequential, parallel']
  status varchar(50) [not null, default: 'pending', note: 'pending, approved, rejected, skipped']
  comment text
  approved_at timestamp
  created_at timestamp [not null, default: `now()`]

  indexes {
    document_id
    approver_id
    status
  }

  Note: 'Маршруты согласования документов'
}

Table document_permissions {
  id bigserial [pk, increment]
  document_id bigint [not null, ref: > documents.id]
  user_id bigint [ref: > users.id]
  role varchar(50) [note: 'admin, secretary, methodist, teacher, student']
  permission varchar(50) [not null, note: 'read, write, delete, admin']
  granted_by bigint [ref: > users.id]
  expires_at timestamp [note: 'Срок действия прав (NULL = бессрочно)']
  created_at timestamp [not null, default: `now()`]

  indexes {
    document_id
    user_id
    role
  }

  Note: 'Права доступа к документам (user_id или role обязательно)'
}

Table document_public_links {
  id bigserial [pk, increment]
  document_id bigint [not null, ref: > documents.id]
  token varchar(64) [unique, not null, note: 'Уникальный токен для доступа']
  permission varchar(50) [not null, default: 'read', note: 'read, download']
  created_by bigint [not null, ref: > users.id]
  expires_at timestamp [note: 'Срок действия ссылки (NULL = бессрочно)']
  max_uses int [note: 'Максимальное количество использований (NULL = неограничено)']
  use_count int [not null, default: 0, note: 'Счётчик использований']
  password_hash varchar(255) [note: 'Опциональный пароль для доступа']
  is_active boolean [not null, default: true]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    document_id
    token
    created_by
    expires_at
    is_active
  }

  Note: 'Публичные ссылки для документов'
}

Table document_relations {
  id bigserial [pk, increment]
  document_id bigint [not null, ref: > documents.id]
  related_document_id bigint [not null, ref: > documents.id]
  relation_type varchar(50) [not null, note: 'reply, attachment, reference, supersedes, amendment']
  description text
  created_at timestamp [not null, default: `now()`]

  indexes {
    document_id
    related_document_id
    relation_type
  }

  Note: 'Связи между документами'
}

Table document_tags {
  id bigserial [pk, increment]
  name varchar(100) [not null, unique]
  color varchar(7) [note: 'HEX color']
  created_at timestamp [not null, default: `now()`]

  Note: 'Теги для документов'
}

Table document_tag_relations {
  document_id bigint [not null, ref: > documents.id]
  tag_id bigint [not null, ref: > document_tags.id]
  created_at timestamp [not null, default: `now()`]

  indexes {
    (document_id, tag_id) [pk]
    tag_id
  }

  Note: 'Связь документов и тегов'
}

Table document_history {
  id bigserial [pk, increment]
  document_id bigint [not null, ref: > documents.id]
  user_id bigint [ref: > users.id]
  action varchar(100) [not null, note: 'created, updated, approved, rejected, archived']
  details jsonb
  ip_address varchar(45)
  user_agent varchar(500)
  created_at timestamp [not null, default: `now()`]

  indexes {
    document_id
    user_id
    action
    created_at
  }

  Note: 'История изменений документов (аудит)'
}

// ============================================================================
// SCHEDULE MODULE - Расписание (13 таблиц)
// ============================================================================

Table academic_years {
  id bigserial [pk, increment]
  name varchar(50) [not null, unique, note: '2023/2024']
  start_date date [not null]
  end_date date [not null]
  is_current boolean [not null, default: false]
  created_at timestamp [not null, default: `now()`]

  Note: 'Учебные годы'
}

Table semesters {
  id bigserial [pk, increment]
  academic_year_id bigint [not null, ref: > academic_years.id]
  name varchar(50) [not null, note: 'Осенний, Весенний']
  semester_number int [not null, note: '1 or 2']
  start_date date [not null]
  end_date date [not null]
  is_current boolean [not null, default: false]
  created_at timestamp [not null, default: `now()`]

  indexes {
    academic_year_id
    is_current
  }

  Note: 'Семестры'
}

Table faculties {
  id bigserial [pk, increment]
  name varchar(255) [not null, unique]
  short_name varchar(50)
  code varchar(50) [unique]
  dean_id bigint [ref: > users.id]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  Note: 'Факультеты/Институты'
}

Table departments {
  id bigserial [pk, increment]
  faculty_id bigint [not null, ref: > faculties.id]
  name varchar(255) [not null]
  short_name varchar(50)
  code varchar(50) [unique]
  head_id bigint [ref: > users.id]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    faculty_id
  }

  Note: 'Академические кафедры (привязаны к факультетам)'
}

Table specialties {
  id bigserial [pk, increment]
  department_id bigint [not null, ref: > departments.id]
  name varchar(255) [not null]
  code varchar(50) [unique, note: '38.03.01']
  degree_level varchar(50) [note: 'bachelor, master, specialist']
  duration_years int
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    department_id
    code
  }

  Note: 'Специальности/Направления подготовки'
}

Table student_groups {
  id bigserial [pk, increment]
  specialty_id bigint [not null, ref: > specialties.id]
  name varchar(100) [not null, unique, note: 'ЭК-201']
  course_number int [not null]
  admission_year int [not null]
  curator_id bigint [ref: > users.id]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    specialty_id
    course_number
  }

  Note: 'Учебные группы студентов'
}

Table disciplines {
  id bigserial [pk, increment]
  name varchar(255) [not null]
  code varchar(50) [unique]
  credits int
  total_hours int
  lecture_hours int
  practice_hours int
  lab_hours int
  description text
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  Note: 'Учебные дисциплины'
}

Table curriculum_plans {
  id bigserial [pk, increment]
  specialty_id bigint [not null, ref: > specialties.id]
  academic_year_id bigint [not null, ref: > academic_years.id]
  name varchar(255) [not null]
  approved_at timestamp
  approved_by bigint [ref: > users.id]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    specialty_id
    academic_year_id
  }

  Note: 'Учебные планы'
}

Table curriculum_disciplines {
  id bigserial [pk, increment]
  curriculum_plan_id bigint [not null, ref: > curriculum_plans.id]
  discipline_id bigint [not null, ref: > disciplines.id]
  semester_number int [not null]
  credits int
  lecture_hours int
  practice_hours int
  lab_hours int
  control_type varchar(50) [note: 'exam, credit, diff_credit']
  created_at timestamp [not null, default: `now()`]

  indexes {
    curriculum_plan_id
    discipline_id
    semester_number
  }

  Note: 'Дисциплины в учебных планах'
}

Table classrooms {
  id bigserial [pk, increment]
  building varchar(50)
  room_number varchar(50) [not null]
  name varchar(255) [unique, note: '101А, Актовый зал']
  capacity int
  classroom_type varchar(50) [note: 'lecture, laboratory, computer, sports']
  equipment jsonb [note: 'Проектор, компьютеры и т.д.']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  Note: 'Аудитории'
}

Table lesson_types {
  id bigserial [pk, increment]
  name varchar(100) [not null, unique, note: 'Лекция, Практика, Лабораторная']
  code varchar(50) [not null, unique]
  color varchar(7) [note: 'HEX color для UI']
  created_at timestamp [not null, default: `now()`]

  Note: 'Типы занятий'
}

Table schedule_lessons {
  id bigserial [pk, increment]
  semester_id bigint [not null, ref: > semesters.id]
  discipline_id bigint [not null, ref: > disciplines.id]
  teacher_id bigint [not null, ref: > users.id]
  group_id bigint [not null, ref: > student_groups.id]
  classroom_id bigint [not null, ref: > classrooms.id]
  lesson_type_id bigint [not null, ref: > lesson_types.id]

  day_of_week int [not null, note: '1-7 (Mon-Sun)']
  time_start time [not null]
  time_end time [not null]
  week_type varchar(20) [note: 'all, odd, even']

  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    semester_id
    discipline_id
    teacher_id
    group_id
    classroom_id
    day_of_week
    (classroom_id, day_of_week, time_start)
  }

  Note: 'Расписание занятий'
}

Table schedule_changes {
  id bigserial [pk, increment]
  schedule_lesson_id bigint [not null, ref: > schedule_lessons.id]
  change_date date [not null]
  change_type varchar(50) [not null, note: 'cancellation, move, replacement']

  new_teacher_id bigint [ref: > users.id]
  new_classroom_id bigint [ref: > classrooms.id]
  new_time_start time
  new_time_end time

  reason text
  created_by bigint [not null, ref: > users.id]
  created_at timestamp [not null, default: `now()`]

  indexes {
    schedule_lesson_id
    change_date
  }

  Note: 'Замены и изменения расписания'
}

// ============================================================================
// TASKS MODULE - Управление задачами (11 таблиц)
// ============================================================================

Table projects {
  id bigserial [pk, increment]
  name varchar(255) [not null]
  description text
  owner_id bigint [not null, ref: > users.id]
  status varchar(50) [not null, default: 'active', note: 'planning, active, on_hold, completed, cancelled']
  start_date date
  end_date date
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    owner_id
    status
  }

  Note: 'Проекты для группировки задач'
}

Table tasks {
  id bigserial [pk, increment]
  project_id bigint [ref: > projects.id]

  title varchar(500) [not null]
  description text

  document_id bigint [ref: > documents.id]

  author_id bigint [not null, ref: > users.id]
  assignee_id bigint [ref: > users.id]

  status varchar(50) [not null, default: 'new', note: 'new, assigned, in_progress, review, completed, cancelled, deferred']
  priority varchar(50) [not null, default: 'normal', note: 'low, normal, high, urgent']

  due_date timestamp
  start_date timestamp
  completed_at timestamp

  progress int [default: 0, note: '0-100%']
  estimated_hours decimal(10,2)
  actual_hours decimal(10,2)

  tags text[] [note: 'Массив тегов']
  metadata jsonb

  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    project_id
    document_id
    author_id
    assignee_id
    status
    priority
    due_date
  }

  Note: 'Задачи и поручения'
}

Table task_watchers {
  task_id bigint [not null, ref: > tasks.id]
  user_id bigint [not null, ref: > users.id]
  created_at timestamp [not null, default: `now()`]

  indexes {
    (task_id, user_id) [pk]
    user_id
  }

  Note: 'Наблюдатели задач'
}

Table task_attachments {
  id bigserial [pk, increment]
  task_id bigint [not null, ref: > tasks.id]
  file_name varchar(500) [not null]
  file_path varchar(1000) [not null]
  file_size bigint [not null]
  mime_type varchar(100)
  uploaded_by bigint [not null, ref: > users.id]
  created_at timestamp [not null, default: `now()`]

  indexes {
    task_id
  }

  Note: 'Вложения к задачам'
}

Table task_comments {
  id bigserial [pk, increment]
  task_id bigint [not null, ref: > tasks.id]
  author_id bigint [not null, ref: > users.id]
  content text [not null]
  parent_comment_id bigint [ref: > task_comments.id]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    task_id
    author_id
    parent_comment_id
  }

  Note: 'Комментарии к задачам'
}

Table task_checklists {
  id bigserial [pk, increment]
  task_id bigint [not null, ref: > tasks.id]
  title varchar(500) [not null]
  position int [not null, default: 0]
  created_at timestamp [not null, default: `now()`]

  indexes {
    task_id
  }

  Note: 'Чеклисты задач'
}

Table task_checklist_items {
  id bigserial [pk, increment]
  checklist_id bigint [not null, ref: > task_checklists.id]
  title varchar(500) [not null]
  is_completed boolean [not null, default: false]
  position int [not null, default: 0]
  completed_by bigint [ref: > users.id]
  completed_at timestamp
  created_at timestamp [not null, default: `now()`]

  indexes {
    checklist_id
  }

  Note: 'Элементы чеклистов'
}

Table task_dependencies {
  id bigserial [pk, increment]
  task_id bigint [not null, ref: > tasks.id]
  depends_on_task_id bigint [not null, ref: > tasks.id]
  dependency_type varchar(50) [not null, default: 'finish_to_start', note: 'finish_to_start, start_to_start, finish_to_finish, start_to_finish']
  created_at timestamp [not null, default: `now()`]

  indexes {
    task_id
    depends_on_task_id
  }

  Note: 'Зависимости задач (для диаграмм Ганта)'
}

Table task_history {
  id bigserial [pk, increment]
  task_id bigint [not null, ref: > tasks.id]
  user_id bigint [ref: > users.id]
  field_name varchar(100) [not null]
  old_value text
  new_value text
  created_at timestamp [not null, default: `now()`]

  indexes {
    task_id
    user_id
    created_at
  }

  Note: 'История изменений задач'
}

Table task_reminders {
  id bigserial [pk, increment]
  task_id bigint [not null, ref: > tasks.id]
  user_id bigint [not null, ref: > users.id]
  remind_at timestamp [not null]
  is_sent boolean [not null, default: false]
  sent_at timestamp
  created_at timestamp [not null, default: `now()`]

  indexes {
    task_id
    user_id
    remind_at
  }

  Note: 'Напоминания о задачах'
}

Table task_templates {
  id bigserial [pk, increment]
  name varchar(255) [not null]
  description text
  title_template varchar(500) [not null]
  description_template text
  default_priority varchar(50) [not null, default: 'normal']
  default_estimated_hours decimal(10,2)
  checklist_items jsonb
  created_by bigint [not null, ref: > users.id]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    created_by
  }

  Note: 'Шаблоны задач'
}

// ============================================================================
// REPORTS MODULE - Отчётность (10 таблиц)
// ============================================================================

Table report_types {
  id bigserial [pk, increment]
  name varchar(255) [not null, unique]
  code varchar(50) [not null, unique]
  description text
  category varchar(100) [note: 'academic, administrative, financial, methodical']
  template_path varchar(500)
  output_format varchar(50) [default: 'pdf', note: 'pdf, xlsx, docx, html']
  is_periodic boolean [not null, default: false]
  period_type varchar(50) [note: 'daily, weekly, monthly, quarterly, annual']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  Note: 'Типы отчётов'
}

Table report_parameters {
  id bigserial [pk, increment]
  report_type_id bigint [not null, ref: > report_types.id]
  parameter_name varchar(100) [not null]
  parameter_type varchar(50) [not null, note: 'string, number, date, boolean, select, multiselect']
  is_required boolean [not null, default: true]
  default_value text
  options jsonb
  display_order int [not null, default: 0]
  created_at timestamp [not null, default: `now()`]

  indexes {
    report_type_id
  }

  Note: 'Параметры отчётов'
}

Table reports {
  id bigserial [pk, increment]
  report_type_id bigint [not null, ref: > report_types.id]

  title varchar(500) [not null]
  description text

  period_start date
  period_end date

  author_id bigint [not null, ref: > users.id]

  status varchar(50) [not null, default: 'draft', note: 'draft, generating, ready, reviewing, approved, rejected, published']

  file_name varchar(500)
  file_path varchar(1000)
  file_size bigint
  mime_type varchar(100)

  parameters jsonb [note: 'Параметры генерации']
  data jsonb [note: 'Агрегированные метрики']

  reviewer_comment text
  reviewed_by bigint [ref: > users.id]
  reviewed_at timestamp

  published_at timestamp
  is_public boolean [not null, default: false]

  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    report_type_id
    author_id
    status
    (period_start, period_end)
    created_at
  }

  Note: 'Сгенерированные отчёты'
}

Table report_access {
  id bigserial [pk, increment]
  report_id bigint [not null, ref: > reports.id]
  user_id bigint [ref: > users.id]
  role varchar(50) [note: 'admin, secretary, methodist, teacher, student']
  permission varchar(50) [not null, note: 'read, write, approve, publish']
  granted_by bigint [ref: > users.id]
  created_at timestamp [not null, default: `now()`]

  indexes {
    report_id
    user_id
    role
  }

  Note: 'Права доступа к отчётам'
}

Table report_comments {
  id bigserial [pk, increment]
  report_id bigint [not null, ref: > reports.id]
  author_id bigint [not null, ref: > users.id]
  content text [not null]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    report_id
    author_id
  }

  Note: 'Комментарии к отчётам'
}

Table report_generation_log {
  id bigserial [pk, increment]
  report_id bigint [not null, ref: > reports.id]
  started_at timestamp [not null, default: `now()`]
  completed_at timestamp
  status varchar(50) [not null, note: 'started, completed, failed']
  error_message text
  duration_seconds int
  records_processed int

  indexes {
    report_id
    status
  }

  Note: 'Журнал генерации отчётов'
}

Table report_subscriptions {
  id bigserial [pk, increment]
  report_type_id bigint [not null, ref: > report_types.id]
  user_id bigint [not null, ref: > users.id]
  delivery_method varchar(50) [not null, default: 'email', note: 'email, notification, both']
  is_active boolean [not null, default: true]
  created_at timestamp [not null, default: `now()`]

  indexes {
    user_id
    is_active
    (report_type_id, user_id) [unique]
  }

  Note: 'Подписки на отчёты'
}

Table report_templates {
  id bigserial [pk, increment]
  report_type_id bigint [not null, ref: > report_types.id]
  name varchar(255) [not null]
  content text [not null, note: 'HTML/LaTeX шаблон']
  is_default boolean [not null, default: false]
  created_by bigint [not null, ref: > users.id]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    report_type_id
    is_default
  }

  Note: 'Шаблоны отчётов'
}

Table report_history {
  id bigserial [pk, increment]
  report_id bigint [not null, ref: > reports.id]
  user_id bigint [ref: > users.id]
  action varchar(100) [not null, note: 'created, updated, approved, rejected, published']
  details jsonb
  created_at timestamp [not null, default: `now()`]

  indexes {
    report_id
    user_id
    created_at
  }

  Note: 'История изменений отчётов'
}

Table custom_reports {
  id uuid [pk, default: `gen_random_uuid()`]
  name varchar(255) [not null]
  description text
  data_source varchar(50) [not null, note: 'documents, users, events, tasks, students']
  fields jsonb [not null, default: '[]', note: 'Конфигурация выбранных полей']
  filters jsonb [not null, default: '[]', note: 'Условия фильтрации']
  groupings jsonb [not null, default: '[]', note: 'Конфигурация группировки']
  sortings jsonb [not null, default: '[]', note: 'Конфигурация сортировки']
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  created_by bigint [not null, ref: > users.id]
  is_public boolean [not null, default: false]

  indexes {
    created_by
    data_source
    is_public
    updated_at
  }

  Note: 'Пользовательские шаблоны отчётов для конструктора отчётов'
}

// ============================================================================
// EVENTS MODULE - Календарь и события (4 таблицы)
// ============================================================================

Table events {
  id bigserial [pk, increment]
  title varchar(500) [not null]
  description text
  event_type varchar(50) [not null, note: 'meeting, deadline, task, reminder, holiday, personal']
  status varchar(50) [not null, default: 'scheduled', note: 'scheduled, ongoing, completed, cancelled']

  start_time timestamp [not null]
  end_time timestamp
  all_day boolean [not null, default: false]
  timezone varchar(50) [not null, default: 'Europe/Moscow']

  location varchar(500)
  organizer_id bigint [not null, ref: > users.id]

  is_recurring boolean [not null, default: false]
  recurrence_rule jsonb [note: '{"frequency": "weekly", "interval": 1, "byDay": ["MO", "WE"]}']
  parent_event_id bigint [ref: > events.id]
  recurrence_id varchar(100)

  color varchar(20)
  priority int [not null, default: 0, note: '0-3']

  metadata jsonb
  external_id varchar(255)

  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp

  indexes {
    organizer_id
    start_time
    end_time
    event_type
    status
    is_recurring
    parent_event_id
    deleted_at
    (start_time, end_time)
  }

  Note: 'События календаря'
}

Table event_participants {
  id bigserial [pk, increment]
  event_id bigint [not null, ref: > events.id]
  user_id bigint [not null, ref: > users.id]
  response_status varchar(50) [not null, default: 'pending', note: 'pending, accepted, declined, tentative']
  role varchar(50) [not null, default: 'required', note: 'required, optional, organizer']
  notified_at timestamp
  responded_at timestamp
  created_at timestamp [not null, default: `now()`]

  indexes {
    event_id
    user_id
    response_status
    (event_id, user_id) [unique]
  }

  Note: 'Участники событий'
}

Table event_reminders {
  id bigserial [pk, increment]
  event_id bigint [not null, ref: > events.id]
  user_id bigint [not null, ref: > users.id]
  reminder_type varchar(50) [not null, default: 'in_app', note: 'email, push, in_app']
  minutes_before int [not null, default: 15]
  is_sent boolean [not null, default: false]
  sent_at timestamp
  created_at timestamp [not null, default: `now()`]

  indexes {
    event_id
    user_id
    is_sent
  }

  Note: 'Напоминания о событиях'
}

Table event_recurrence_exceptions {
  id bigserial [pk, increment]
  event_id bigint [not null, ref: > events.id]
  exception_date date [not null]
  created_at timestamp [not null, default: `now()`]

  indexes {
    event_id
    exception_date
    (event_id, exception_date) [unique]
  }

  Note: 'Исключения из повторяющихся событий'
}

// ============================================================================
// ANNOUNCEMENTS MODULE - Объявления (2 таблицы)
// ============================================================================

Table announcements {
  id bigserial [pk, increment]
  title varchar(500) [not null]
  content text [not null]
  summary varchar(1000)

  author_id bigint [not null, ref: > users.id]

  status varchar(50) [not null, default: 'draft', note: 'draft, published, archived']
  priority varchar(50) [not null, default: 'normal', note: 'low, normal, high, urgent']

  target_audience varchar(50) [not null, default: 'all', note: 'all, students, teachers, staff, admins']

  publish_at timestamp
  expire_at timestamp

  is_pinned boolean [not null, default: false]
  view_count bigint [not null, default: 0]

  tags text[]
  metadata jsonb

  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    author_id
    status
    priority
    target_audience
    publish_at
    expire_at
    is_pinned
    created_at
  }

  Note: 'Объявления и новости'
}

Table announcement_attachments {
  id bigserial [pk, increment]
  announcement_id bigint [not null, ref: > announcements.id]
  file_name varchar(500) [not null]
  file_path varchar(1000) [not null]
  file_size bigint [not null]
  mime_type varchar(100)
  uploaded_by bigint [not null, ref: > users.id]
  created_at timestamp [not null, default: `now()`]

  indexes {
    announcement_id
  }

  Note: 'Вложения к объявлениям'
}

// ============================================================================
// FILES MODULE - Файловое хранилище (2 таблицы)
// ============================================================================

Table file_metadata {
  id bigserial [pk, increment]
  original_name varchar(500) [not null, note: 'Оригинальное имя файла']
  storage_key varchar(1000) [unique, not null, note: 'Ключ в S3/MinIO хранилище']
  size bigint [not null, note: 'Размер файла в байтах']
  mime_type varchar(100) [not null]
  checksum varchar(64) [not null, note: 'SHA-256 хеш файла']
  uploaded_by bigint [not null, ref: > users.id]
  document_id bigint [ref: > documents.id, note: 'Связь с документом']
  task_id bigint [ref: > tasks.id, note: 'Связь с задачей']
  announcement_id bigint [ref: > announcements.id, note: 'Связь с объявлением']
  is_temporary boolean [not null, default: true, note: 'Временный файл до прикрепления']
  expires_at timestamp [note: 'Срок жизни временного файла']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp [note: 'Мягкое удаление']

  indexes {
    uploaded_by
    document_id
    task_id
    announcement_id
    is_temporary
    expires_at
    deleted_at
    created_at
    checksum
  }

  Note: 'Метаданные файлов в хранилище MinIO/S3'
}

Table file_versions {
  id bigserial [pk, increment]
  file_metadata_id bigint [not null, ref: > file_metadata.id]
  version_number int [not null, note: 'Номер версии']
  storage_key varchar(1000) [not null, note: 'Ключ версии в S3/MinIO']
  size bigint [not null]
  checksum varchar(64) [not null]
  comment varchar(500) [note: 'Описание изменений']
  created_by bigint [not null, ref: > users.id]
  created_at timestamp [not null, default: `now()`]

  indexes {
    file_metadata_id
    created_by
    created_at
    (file_metadata_id, version_number) [unique]
  }

  Note: 'Версии файлов для поддержки версионирования документов'
}

// ============================================================================
// NOTIFICATIONS MODULE - Уведомления (6 таблиц)
// ============================================================================

// Enums: notification_type, notification_priority

Table notifications {
  id bigserial [pk, increment]
  user_id bigint [not null, ref: > users.id]
  type varchar(50) [not null, default: 'info', note: 'info, success, warning, error, reminder, task, document, event, system']
  priority varchar(50) [not null, default: 'normal', note: 'low, normal, high, urgent']
  title varchar(500) [not null]
  message text [not null]
  link varchar(1000)
  image_url varchar(1000)
  is_read boolean [not null, default: false]
  read_at timestamp
  expires_at timestamp
  metadata jsonb
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    user_id
    (user_id, is_read)
    (user_id, created_at)
    type
    priority
    expires_at
    created_at
  }

  Note: 'In-app уведомления пользователей'
}

Table notification_preferences {
  id bigserial [pk, increment]
  user_id bigint [unique, not null, ref: > users.id]

  // Channel preferences
  email_enabled boolean [not null, default: true]
  push_enabled boolean [not null, default: true]
  in_app_enabled boolean [not null, default: true]
  telegram_enabled boolean [not null, default: false]
  slack_enabled boolean [not null, default: false]

  // Quiet hours
  quiet_hours_enabled boolean [not null, default: false]
  quiet_hours_start varchar(5) [not null, default: '22:00']
  quiet_hours_end varchar(5) [not null, default: '07:00']
  timezone varchar(50) [not null, default: 'Europe/Moscow']

  // Digest settings
  digest_enabled boolean [not null, default: false]
  digest_frequency varchar(20) [not null, default: 'daily']
  digest_time varchar(5) [not null, default: '09:00']

  type_preferences jsonb [note: 'Type-specific preferences']

  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    user_id
  }

  Note: 'Настройки уведомлений пользователей'
}

Table user_telegram_connections {
  user_id bigint [pk, ref: > users.id]
  telegram_chat_id bigint [not null]
  telegram_username varchar(255)
  telegram_first_name varchar(255)
  is_active boolean [not null, default: true]
  connected_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    telegram_chat_id
  }

  Note: 'Привязка Telegram аккаунтов'
}

Table user_slack_connections {
  user_id bigint [pk, ref: > users.id]
  slack_user_id varchar(255) [not null]
  slack_channel_id varchar(255)
  slack_workspace_id varchar(255)
  slack_username varchar(255)
  is_active boolean [not null, default: true]
  connected_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    slack_user_id
  }

  Note: 'Привязка Slack аккаунтов'
}

Table notification_delivery_log {
  id bigserial [pk, increment]
  notification_id bigint [ref: > notifications.id]
  user_id bigint [not null, ref: > users.id]
  channel varchar(50) [not null, note: 'email, push, telegram, slack, in_app']
  status varchar(50) [not null, default: 'pending', note: 'pending, sent, delivered, failed, bounced']
  external_id varchar(255) [note: 'External message ID from channel']
  error_message text
  sent_at timestamp
  delivered_at timestamp
  created_at timestamp [not null, default: `now()`]

  indexes {
    notification_id
    (user_id, channel)
    status
    created_at
  }

  Note: 'Лог доставки уведомлений по каналам'
}

Table telegram_verification_codes {
  id bigserial [pk, increment]
  user_id bigint [not null, ref: > users.id]
  code varchar(8) [unique, not null]
  expires_at timestamp [not null]
  used_at timestamp
  created_at timestamp [not null, default: `now()`]

  indexes {
    code
    user_id
    expires_at
  }

  Note: 'Коды верификации для привязки Telegram'
}

// ============================================================================
// INTEGRATION MODULE - Интеграция с 1С (4 таблицы)
// ============================================================================

// Enums: sync_status, sync_direction, sync_entity_type, conflict_resolution

Table sync_logs {
  id bigserial [pk, increment]
  entity_type varchar(50) [not null, note: 'employee, student, finance']
  direction varchar(50) [not null, note: 'import, export, both']
  status varchar(50) [not null, default: 'pending', note: 'pending, in_progress, completed, failed, cancelled']
  started_at timestamp [not null, default: `now()`]
  completed_at timestamp
  total_records int [not null, default: 0]
  processed_count int [not null, default: 0]
  success_count int [not null, default: 0]
  error_count int [not null, default: 0]
  conflict_count int [not null, default: 0]
  error_message text
  metadata jsonb [default: '{}']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    entity_type
    status
    started_at
    (entity_type, status)
  }

  Note: 'Логи синхронизации с системой 1С'
}

Table external_employees {
  id bigserial [pk, increment]
  external_id varchar(50) [unique, not null, note: '1C GUID (Ref_Key)']
  code varchar(50) [not null, note: '1C Code']
  first_name varchar(100) [not null]
  last_name varchar(100) [not null]
  middle_name varchar(100)
  email varchar(255)
  phone varchar(50)
  position varchar(255)
  department varchar(255)
  employment_date date
  dismissal_date date
  is_active boolean [not null, default: true]
  local_user_id bigint [ref: > users.id]
  last_sync_at timestamp [not null, default: `now()`]
  external_data_hash varchar(64) [note: 'SHA256 hash for change detection']
  raw_data jsonb [note: 'Original JSON from 1C']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    code
    email
    local_user_id
    is_active
    department
    last_sync_at
  }

  Note: 'Сотрудники из системы 1С'
}

Table external_students {
  id bigserial [pk, increment]
  external_id varchar(50) [unique, not null, note: '1C GUID (Ref_Key)']
  code varchar(50) [not null, note: '1C Code (зачетка)']
  first_name varchar(100) [not null]
  last_name varchar(100) [not null]
  middle_name varchar(100)
  email varchar(255)
  phone varchar(50)
  group_name varchar(100)
  faculty varchar(255)
  specialty varchar(255)
  course int
  study_form varchar(100)
  enrollment_date date
  expulsion_date date
  graduation_date date
  status varchar(50) [not null, default: 'enrolled', note: 'enrolled, graduated, expelled, academic_leave']
  is_active boolean [not null, default: true]
  local_user_id bigint [ref: > users.id]
  last_sync_at timestamp [not null, default: `now()`]
  external_data_hash varchar(64) [note: 'SHA256 hash for change detection']
  raw_data jsonb [note: 'Original JSON from 1C']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    code
    email
    local_user_id
    is_active
    group_name
    faculty
    course
    status
    last_sync_at
  }

  Note: 'Студенты из системы 1С'
}

Table sync_conflicts {
  id bigserial [pk, increment]
  sync_log_id bigint [not null, ref: > sync_logs.id]
  entity_type varchar(50) [not null, note: 'employee, student, finance']
  entity_id varchar(50) [not null, note: 'External ID or local ID']
  local_data jsonb [note: 'JSON of local record']
  external_data jsonb [note: 'JSON of external record']
  conflict_type varchar(50) [not null, note: 'update, delete, create']
  conflict_fields text[] [note: 'Fields with conflicts']
  resolution varchar(50) [not null, default: 'pending', note: 'pending, use_local, use_external, merge, skip']
  resolved_by bigint [ref: > users.id]
  resolved_at timestamp
  resolved_data jsonb [note: 'Final merged data']
  notes text
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    sync_log_id
    entity_type
    resolution
    created_at
  }

  Note: 'Конфликты данных при синхронизации с 1С'
}

// ============================================================================
// MESSAGING MODULE - Внутренняя переписка (4 таблицы)
// ============================================================================

Table conversations {
  id bigserial [pk, increment]
  type varchar(20) [not null, default: 'direct', note: 'direct, group']
  title varchar(255)
  description text
  avatar_url varchar(500)
  created_by bigint [not null, ref: > users.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    created_by
    type
    updated_at
  }

  Note: 'Чаты (прямые и групповые)'
}

Table conversation_participants {
  id bigserial [pk, increment]
  conversation_id bigint [not null, ref: > conversations.id]
  user_id bigint [not null, ref: > users.id]
  role varchar(20) [not null, default: 'member', note: 'member, admin']
  last_read_at timestamptz
  last_read_message_id bigint [ref: > messages.id]
  is_muted boolean [not null, default: false]
  joined_at timestamptz [not null, default: `now()`]
  left_at timestamptz

  indexes {
    user_id
    conversation_id
    (conversation_id, user_id) [unique]
  }

  Note: 'Участники чатов'
}

Table messages {
  id bigserial [pk, increment]
  conversation_id bigint [not null, ref: > conversations.id]
  sender_id bigint [ref: > users.id]
  type varchar(20) [not null, default: 'text', note: 'text, image, file, system']
  content text [not null]
  reply_to_id bigint [ref: > messages.id]
  is_edited boolean [not null, default: false]
  edited_at timestamptz
  is_deleted boolean [not null, default: false]
  deleted_at timestamptz
  search_vector tsvector [note: 'Генерируемое поле для полнотекстового поиска']
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (conversation_id, created_at)
    sender_id
    reply_to_id
  }

  Note: 'Сообщения в чатах'
}

Table message_attachments {
  id bigserial [pk, increment]
  message_id bigint [not null, ref: > messages.id]
  file_id bigint [not null, ref: > file_metadata.id]
  file_name varchar(255) [not null]
  file_size bigint [not null, default: 0]
  mime_type varchar(100) [not null]
  url varchar(500) [not null]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    message_id
  }

  Note: 'Вложения к сообщениям'
}

// ============================================================================
// СЛУЖЕБНАЯ ТАБЛИЦА
// ============================================================================

Table schema_migrations {
  version bigint [pk]
  dirty boolean [not null]

  Note: 'Версии миграций (golang-migrate)'
}
