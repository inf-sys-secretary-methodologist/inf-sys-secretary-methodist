# .env.deploy.example
# Environment variables for deployment (staging/production)
# Copy to .env.deploy and fill in the values

# ======================
# Docker Images (GHCR)
# ======================
BACKEND_IMAGE=ghcr.io/inf-sys-secretary-methodologist/inf-sys-secretary-methodist/backend
FRONTEND_IMAGE=ghcr.io/inf-sys-secretary-methodologist/inf-sys-secretary-methodist/frontend
BACKEND_TAG=latest
FRONTEND_TAG=latest

# ======================
# Database Configuration
# ======================
POSTGRES_DB=inf_sys_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here
DB_SSL_MODE=require
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=10m

# ======================
# Redis Configuration
# ======================
REDIS_PASSWORD=your-redis-password-here
REDIS_DB=0
REDIS_POOL_SIZE=20

# ======================
# JWT Authentication
# ======================
# Generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ======================
# Server Configuration
# ======================
BACKEND_PORT=8080
FRONTEND_PORT=3000
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=120s

# ======================
# CORS Configuration
# ======================
CORS_ALLOWED_ORIGINS=https://your-domain.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# ======================
# Logging
# ======================
LOG_LEVEL=info
LOG_FORMAT=json

# ======================
# Application
# ======================
ENVIRONMENT=production
VERSION=0.1.0

# ======================
# External Integrations
# ======================
COMPOSIO_API_KEY=
COMPOSIO_ENTITY_ID=
COMPOSIO_MCP_CONFIG_ID=

# ======================
# Frontend
# ======================
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# ======================
# GitHub Secrets (configure in GitHub repo settings)
# ======================
# Required for deployment:
# - STAGING_HOST: Staging server hostname/IP
# - STAGING_USER: SSH username for staging
# - STAGING_SSH_KEY: SSH private key for staging deployment
# - PRODUCTION_HOST: Production server hostname/IP
# - PRODUCTION_USER: SSH username for production
# - PRODUCTION_SSH_KEY: SSH private key for production deployment
#
# Optional for notifications:
# - SLACK_WEBHOOK_URL: Slack incoming webhook URL
# - DISCORD_WEBHOOK_URL: Discord webhook URL
#
# GitHub Variables (configure in GitHub repo settings):
# - STAGING_URL: https://staging.your-domain.com
# - PRODUCTION_URL: https://your-domain.com
